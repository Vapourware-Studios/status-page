# Statch secrets — dotenv format.
#
# Local dev: copy this file to `.dev.vars` and fill in real values.
# Deploy to Cloudflare button: you'll be prompted for these during deploy.
# Manual deploy: set each with `npx wrangler secret put NAME`.

# Required — password for the /admin panel. Set your own strong value.
ADMIN_PASSWORD=""

# Required — any random 32+ character string used to sign sessions.
SESSION_SECRET=""

# Optional — only needed if you enable Discord OAuth login.
DISCORD_CLIENT_SECRET=""

# Optional — any ${SECRET} you reference in status.config.yml, e.g.:
# SLACK_WEBHOOK_URL=""
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# PAGERDUTY_ROUTING_KEY=""
# DISCORD_WEBHOOK_URL=""
